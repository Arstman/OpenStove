---
import type { CollectionEntry } from 'astro:content';

const { recipe } = Astro.props;

interface Props {
  recipe: CollectionEntry<'recipes'>;
}

const isScalable = recipe.data.scalable !== false;
const servings = recipe.data.servings || 1;
---

<!-- Serving Size Container -->
<div class="flex flex-col py-3 sm:py-6 lg:py-6">
  {
    isScalable ? (
      <>
        <label for="serving-scale" class="mb-1 text-base">
          Scale recipe (×)
        </label>
        {/* Input Number */}
        <div
          class="corner-squircle max-w-40 rounded-4xl border border-stone-300 bg-stone-50 dark:border-stone-600 dark:bg-stone-700/60 print:max-w-none print:border-0 print:bg-transparent"
          data-hs-input-number
        >
          <div class="flex w-full items-center justify-between gap-x-1">
            <div class="grow px-3 py-2 print:p-0">
              <input
                id="serving-scale"
                class="text-dark w-full [appearance:textfield] border-0 bg-transparent p-0 focus:ring-0 dark:text-stone-100 [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none"
                type="number"
                value="1"
                min="1"
                max="6"
                data-hs-input-number-input
                readonly
                aria-label="Recipe scale multiplier"
              />
            </div>
            <div class="-gap-y-px flex items-center divide-x divide-stone-200 border-s border-stone-200 dark:divide-stone-700 dark:border-stone-700 print:hidden">
              <button
                type="button"
                class="focus-visible:ring-secondary last:corner-squircle inline-flex h-10 w-10 touch-manipulation items-center justify-center gap-x-2 bg-stone-50 text-sm font-medium text-stone-800 transition duration-300 last:rounded-e-4xl hover:bg-orange-100 focus:outline-hidden focus-visible:ring-1 focus-visible:outline-hidden disabled:pointer-events-none disabled:opacity-50 dark:bg-stone-800 dark:text-stone-200 dark:hover:bg-stone-800/30"
                data-hs-input-number-decrement
                aria-label="Decrease scale"
              >
                <svg
                  class="h-3.5 w-3.5 shrink-0"
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 12h14" />
                </svg>
              </button>
              <button
                type="button"
                class="focus-visible:ring-secondary last:corner-squircle inline-flex h-10 w-10 touch-manipulation items-center justify-center gap-x-2 bg-stone-50 text-sm font-medium text-stone-800 transition duration-300 last:rounded-e-4xl hover:bg-orange-100 focus:outline-hidden focus-visible:ring-1 focus-visible:outline-hidden disabled:pointer-events-none disabled:opacity-50 dark:bg-stone-800 dark:text-stone-200 dark:hover:bg-stone-800/30"
                data-hs-input-number-increment
                aria-label="Increase scale"
              >
                <svg
                  class="h-3.5 w-3.5 shrink-0"
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 12h14" />
                  <path d="M12 5v14" />
                </svg>
              </button>
            </div>
          </div>
        </div>
        <p class="mt-1 text-sm text-stone-500 dark:text-stone-400">
          Base recipe serves {servings}
        </p>
        {/* End Input Number */}
      </>
    ) : (
      <div class="flex flex-col">
        <p class="text-dark text-lg font-semibold dark:text-stone-300">
          Serves {servings} people
        </p>
      </div>
    )
  }
</div>
{/* End Serving Size Container */}

{/* Ingredients List Container */}
<div
  class="flex flex-wrap justify-between gap-6 lg:flex-col lg:flex-nowrap lg:justify-normal lg:gap-0 lg:space-y-4"
>
  {
    recipe.data.ingredients?.map(ingredient => (
      <div>
        <p class="text-dark text-lg font-semibold text-balance 2xl:text-xl dark:text-stone-300">
          {ingredient.title}
        </p>
        <ul class="flex max-w-xs flex-col divide-y divide-gray-200 dark:divide-gray-700">
          {ingredient.items.map(item => (
            <li
              data-quantity={item.quantity}
              data-unit={item.unit}
              data-name={item.name}
              class="count inline-flex items-center gap-x-2 px-4 py-3 text-sm text-stone-600 xl:text-base dark:text-stone-400"
            >
              {[item.quantity, item.unit, item.name].filter(Boolean).join(' ')}
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</div>
<script define:vars={{ isScalable }}>
  if (isScalable) {
    const portionSizeInput = document.querySelector(
      '[data-hs-input-number-input]'
    );

    let portionSize = 1;
    const MIN_SCALE = 1;
    const MAX_SCALE = 6;

    function parseFraction(fraction) {
      if (!fraction.includes('/')) {
        return parseFloat(fraction);
      }
      const parts = fraction.split('/');
      const numerator = Number(parts[0]);
      const denominator = Number(parts[1]);
      if (denominator > 0) {
        return numerator / denominator;
      } else {
        return NaN;
      }
    }

    function adjustQuantity(quantity, portionSize) {
      if (!quantity) {
        return '';
      }
      const parsedQuantity = parseFraction(quantity);
      if (Number.isNaN(parsedQuantity)) {
        return quantity;
      }
      const adjustedQuantity = parsedQuantity * portionSize;
      return parseFloat(adjustedQuantity.toFixed(2)).toString();
    }

    function formatIngredient(quantity, unit, name) {
      return [quantity, unit, name]
        .map(part => (part || '').trim())
        .filter(Boolean)
        .join(' ');
    }

    function updateIngredientQuantities() {
      const ingredientCounts = document.querySelectorAll('.count');
      ingredientCounts.forEach(countElement => {
        const quantity = countElement.dataset.quantity;
        const unit = countElement.dataset.unit;
        const name = countElement.dataset.name;
        countElement.textContent = formatIngredient(
          adjustQuantity(quantity || '', portionSize),
          unit || '',
          name || ''
        );
      });
    }

    updateIngredientQuantities();

    function updatePortionSize(newSize) {
      portionSize = Math.min(MAX_SCALE, Math.max(MIN_SCALE, newSize));
      if (portionSizeInput) {
        portionSizeInput.value = portionSize.toString();

        updateIngredientQuantities();

        if (portionSize >= MAX_SCALE) {
          increment?.setAttribute('disabled', 'disabled');
        } else {
          increment?.removeAttribute('disabled');
        }

        if (portionSize <= MIN_SCALE) {
          decrement?.setAttribute('disabled', 'disabled');
        } else {
          decrement?.removeAttribute('disabled');
        }
      }
    }

    const increment = document.querySelector(
      '[data-hs-input-number-increment]'
    );
    const decrement = document.querySelector(
      '[data-hs-input-number-decrement]'
    );

    updatePortionSize(1);

    increment?.addEventListener('click', () => {
      updatePortionSize(portionSize + 1);
    });

    decrement?.addEventListener('click', () => {
      updatePortionSize(portionSize - 1);
    });
  }
</script>
