---
import type { CollectionEntry } from 'astro:content';

const { recipe } = Astro.props;

interface Props {
  recipe: CollectionEntry<'recipes'>;
}

const isScalable = recipe.data.scalable !== false;
const baseServings = recipe.data.servings || 1;
const maxServings = Math.max(baseServings * 6, 12);
---

<!-- Serving Size Container -->
<div class="flex flex-col py-3 sm:py-6 lg:py-6">
  {
    isScalable ? (
      <>
        <label for="serving-count" class="mb-1 text-base">
          Servings
        </label>
        <div
          class="corner-squircle max-w-40 rounded-4xl border border-stone-300 bg-stone-50 dark:border-stone-600 dark:bg-stone-700/60 print:max-w-none print:border-0 print:bg-transparent"
          data-serving-control
          data-base-servings={baseServings}
          data-max-servings={maxServings}
        >
          <div class="flex w-full items-center justify-between gap-x-1">
            <div class="grow px-3 py-2 print:p-0">
              <input
                id="serving-count"
                class="text-dark w-full [appearance:textfield] border-0 bg-transparent p-0 focus:ring-0 dark:text-stone-100 [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none"
                type="number"
                value={baseServings}
                min="1"
                max={maxServings}
                readonly
                aria-label="Number of servings"
                data-serving-input
              />
            </div>
            <div class="-gap-y-px flex items-center divide-x divide-stone-200 border-s border-stone-200 dark:divide-stone-700 dark:border-stone-700 print:hidden">
              <button
                type="button"
                class="focus-visible:ring-secondary last:corner-squircle inline-flex h-10 w-10 touch-manipulation items-center justify-center gap-x-2 bg-stone-50 text-sm font-medium text-stone-800 transition duration-300 last:rounded-e-4xl hover:bg-orange-100 focus:outline-hidden focus-visible:ring-1 focus-visible:outline-hidden disabled:pointer-events-none disabled:opacity-50 dark:bg-stone-800 dark:text-stone-200 dark:hover:bg-stone-800/30"
                data-serving-decrement
                aria-label="Decrease servings"
                disabled={baseServings <= 1}
              >
                <svg
                  class="h-3.5 w-3.5 shrink-0"
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 12h14" />
                </svg>
              </button>
              <button
                type="button"
                class="focus-visible:ring-secondary last:corner-squircle inline-flex h-10 w-10 touch-manipulation items-center justify-center gap-x-2 bg-stone-50 text-sm font-medium text-stone-800 transition duration-300 last:rounded-e-4xl hover:bg-orange-100 focus:outline-hidden focus-visible:ring-1 focus-visible:outline-hidden disabled:pointer-events-none disabled:opacity-50 dark:bg-stone-800 dark:text-stone-200 dark:hover:bg-stone-800/30"
                data-serving-increment
                aria-label="Increase servings"
              >
                <svg
                  class="h-3.5 w-3.5 shrink-0"
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 12h14" />
                  <path d="M12 5v14" />
                </svg>
              </button>
            </div>
          </div>
        </div>
        <p
          class="mt-1 text-sm text-stone-500 dark:text-stone-400"
          data-serving-hint
          hidden
        >
          Scaled from {baseServings}{' '}
          {baseServings === 1 ? 'serving' : 'servings'}
        </p>
      </>
    ) : (
      <div class="flex flex-col">
        <p class="text-dark text-lg font-semibold dark:text-stone-300">
          Serves {baseServings} {baseServings === 1 ? 'person' : 'people'}
        </p>
      </div>
    )
  }
</div>
{/* End Serving Size Container */}

{/* Ingredients List Container */}
<div
  class="flex flex-wrap justify-between gap-6 lg:flex-col lg:flex-nowrap lg:justify-normal lg:gap-0 lg:space-y-4"
>
  {
    recipe.data.ingredients?.map(ingredient => (
      <div>
        <p class="text-dark text-lg font-semibold text-balance 2xl:text-xl dark:text-stone-300">
          {ingredient.title}
        </p>
        <ul class="flex max-w-xs flex-col divide-y divide-stone-200 dark:divide-stone-700">
          {ingredient.items.map(item => (
            <li
              data-quantity={item.quantity}
              data-unit={item.unit}
              data-name={item.name}
              class="count inline-flex items-center gap-x-2 px-4 py-3 text-sm text-stone-600 xl:text-base dark:text-stone-400"
            >
              {[item.quantity, item.unit, item.name].filter(Boolean).join(' ')}
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</div>
<script define:vars={{ isScalable }}>
  if (isScalable) {
    const control = document.querySelector('[data-serving-control]');
    const servingsInput = control?.querySelector('[data-serving-input]');
    const increment = control?.querySelector('[data-serving-increment]');
    const decrement = control?.querySelector('[data-serving-decrement]');
    const hint = document.querySelector('[data-serving-hint]');

    const baseServings = Number(control?.dataset.baseServings) || 1;
    const maxServings = Number(control?.dataset.maxServings) || 12;
    const minServings = 1;

    let currentServings = baseServings;

    const UNICODE_FRACTIONS = {
      '1/2': '½',
      '1/3': '⅓',
      '2/3': '⅔',
      '1/4': '¼',
      '3/4': '¾',
      '1/5': '⅕',
      '2/5': '⅖',
      '3/5': '⅗',
      '4/5': '⅘',
      '1/6': '⅙',
      '5/6': '⅚',
      '1/8': '⅛',
      '3/8': '⅜',
      '5/8': '⅝',
      '7/8': '⅞',
    };

    const FRACTION_CANDIDATES = [
      [1, 8],
      [1, 6],
      [1, 5],
      [1, 4],
      [1, 3],
      [2, 5],
      [1, 2],
      [3, 5],
      [2, 3],
      [3, 4],
      [4, 5],
      [5, 6],
      [3, 8],
      [5, 8],
      [7, 8],
    ];

    function parseFraction(fraction) {
      const value = String(fraction).trim();
      if (!value) return NaN;

      const mixed = value.match(/^(\d+)\s+(\d+)\/(\d+)$/);
      if (mixed) {
        return Number(mixed[1]) + Number(mixed[2]) / Number(mixed[3]);
      }

      if (value.includes('/')) {
        const [numerator, denominator] = value.split('/').map(Number);
        return denominator > 0 ? numerator / denominator : NaN;
      }

      return parseFloat(value);
    }

    function formatQuantity(value) {
      if (!Number.isFinite(value)) return '';

      const rounded = Math.round(value * 1000) / 1000;
      if (Math.abs(rounded) < 0.001) return '';

      const whole = Math.floor(rounded + 1e-9);
      const fractionPart = rounded - whole;

      if (fractionPart < 0.001) {
        return String(whole);
      }

      let best = null;
      let bestError = Infinity;
      for (const [numerator, denominator] of FRACTION_CANDIDATES) {
        const error = Math.abs(fractionPart - numerator / denominator);
        if (error < bestError) {
          bestError = error;
          best = [numerator, denominator];
        }
      }

      if (best && bestError < 0.04) {
        const key = `${best[0]}/${best[1]}`;
        const unicode = UNICODE_FRACTIONS[key];
        const fractionText = unicode || key;
        if (whole === 0) return fractionText;
        return unicode ? `${whole}${unicode}` : `${whole} ${key}`;
      }

      return parseFloat(rounded.toFixed(2)).toString();
    }

    function adjustQuantity(quantity, scale) {
      if (!quantity) return '';
      const parsedQuantity = parseFraction(quantity);
      if (Number.isNaN(parsedQuantity)) return quantity;
      return formatQuantity(parsedQuantity * scale);
    }

    function formatIngredient(quantity, unit, name) {
      return [quantity, unit, name]
        .map(part => (part || '').trim())
        .filter(Boolean)
        .join(' ');
    }

    function updateIngredientQuantities() {
      const scale = currentServings / baseServings;
      document.querySelectorAll('.count').forEach(countElement => {
        const { quantity, unit, name } = countElement.dataset;
        countElement.textContent = formatIngredient(
          adjustQuantity(quantity || '', scale),
          unit || '',
          name || ''
        );
      });
    }

    function updateServings(nextServings) {
      currentServings = Math.min(
        maxServings,
        Math.max(minServings, nextServings)
      );

      if (servingsInput) {
        servingsInput.value = String(currentServings);
      }

      if (hint) {
        hint.hidden = currentServings === baseServings;
      }

      increment?.toggleAttribute('disabled', currentServings >= maxServings);
      decrement?.toggleAttribute('disabled', currentServings <= minServings);

      updateIngredientQuantities();
    }

    updateServings(baseServings);

    increment?.addEventListener('click', () => {
      updateServings(currentServings + 1);
    });

    decrement?.addEventListener('click', () => {
      updateServings(currentServings - 1);
    });
  }
</script>
