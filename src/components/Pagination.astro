---
const { currentPage, totalPages, disablePrevious, disableNext } = Astro.props;

interface Props {
  currentPage: number;
  totalPages: number;
  disablePrevious: boolean;
  disableNext: boolean;
}

function createWindow(
  currentPage: number,
  totalPages: number,
  windowSize: number
) {
  const minPage = Math.max(2, currentPage - windowSize);
  const maxPage = Math.min(totalPages - 1, currentPage + windowSize);
  return Array.from({ length: maxPage - minPage + 1 }, (_, i) => minPage + i);
}

const windowSize = 1;
const baseStyle =
  'flex min-h-[38px] min-w-[38px] items-center justify-center rounded-lg px-3 py-2 text-sm text-dark focus:outline-hidden disabled:pointer-events-none disabled:opacity-50';
const navLinkStyle =
  'inline-flex group min-h-[38px] min-w-[38px] items-center justify-center gap-x-1.5 rounded-lg px-2.5 py-2 text-sm text-dark hover:bg-orange-100 focus:bg-orange-100 focus:outline-hidden dark:text-stone-100 dark:hover:bg-stone-100/5 dark:focus:bg-stone-100/5';
const disabledNavStyle = `${navLinkStyle} pointer-events-none opacity-50`;
---

<nav
  role="navigation"
  aria-label="Pagination"
  class="mt-10 flex items-center justify-center gap-x-1 xl:justify-end"
>
  {
    disablePrevious ? (
      <span class={disabledNavStyle} aria-disabled="true">
        <svg
          class="h-3.5 w-3.5 shrink-0"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6" />
        </svg>
        <span class="hidden sm:inline-block">Previous</span>
      </span>
    ) : (
      <a
        href={'/recipes?page=' + (currentPage - 1)}
        aria-label="Go to previous page"
        class={navLinkStyle}
      >
        <svg
          class="h-3.5 w-3.5 shrink-0 transition ease-in-out group-hover:-translate-x-1"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6" />
        </svg>
        <span class="hidden sm:inline-block">Previous</span>
      </a>
    )
  }
  <div class="flex items-center gap-x-1">
    <a
      href={'/recipes?page=1'}
      class={`${baseStyle} ${currentPage === 1 ? 'bg-orange-200 focus:bg-orange-200 dark:bg-stone-700 dark:text-stone-100 dark:focus:bg-gray-500' : 'hover:bg-orange-100 focus:bg-orange-100 dark:text-white dark:hover:bg-stone-100/5 dark:focus:bg-stone-100/5'}`}
      aria-current={currentPage === 1 ? 'page' : undefined}
      aria-label="Page 1"
    >
      1
    </a>
    {
      currentPage - windowSize > 2 && (
        <div class="hs-tooltip inline-block">
          <a
            href={`/recipes?page=${currentPage - 2 > 1 ? currentPage - 2 : 1}`}
            class="hs-tooltip-toggle group hover:text-primary-accent-light dark:hover-text-primary-accent-dark flex min-h-[38px] min-w-[38px] items-center justify-center rounded-lg p-2 text-sm text-stone-400 hover:bg-orange-100 focus:bg-orange-100 focus:outline-hidden disabled:pointer-events-none disabled:opacity-50 dark:hover:bg-stone-100/5 dark:focus:bg-stone-100/5"
          >
            <span class="text-xs group-hover:hidden">•••</span>
            <svg
              class="hidden h-5 w-5 shrink-0 group-hover:block"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <>
                <path d="m18 7 -5 5 5 5" />
                <path d="m11 7 -5 5 5 5" />
              </>
            </svg>
            <span
              class="hs-tooltip-content hs-tooltip-shown:opacity-100 hs-tooltip-shown:visible invisible absolute z-10 inline-block rounded-sm bg-stone-900 px-2 py-1 text-xs font-medium text-stone-100 opacity-0 shadow-xs transition-opacity dark:bg-stone-700"
              role="tooltip"
            >
              {`Previous ${currentPage - 1 > 3 ? 2 : currentPage - 3 > 1 ? currentPage - 3 : 1} pages`}
            </span>
          </a>
        </div>
      )
    }

    {
      createWindow(currentPage, totalPages, windowSize).map(page => (
        <a
          href={'/recipes?page=' + page}
          class={`${baseStyle} ${currentPage === page ? 'bg-orange-200 focus:bg-orange-200 dark:bg-stone-700 dark:text-stone-100 dark:focus:bg-gray-500' : 'hover:bg-orange-100 focus:bg-orange-100 dark:text-white dark:hover:bg-stone-100/5 dark:focus:bg-stone-100/5'}`}
          aria-current={currentPage === page ? 'page' : undefined}
          aria-label={`Page ${page}`}
        >
          {page}
        </a>
      ))
    }

    {
      currentPage + windowSize < totalPages - 1 && (
        <div class="hs-tooltip inline-block">
          <a
            href={`/recipes?page=${currentPage + windowSize + 1}`}
            class="hs-tooltip-toggle group hover:text-primary-accent-light dark:hover-text-primary-accent-dark flex min-h-[38px] min-w-[38px] items-center justify-center rounded-lg p-2 text-sm text-stone-400 hover:bg-orange-100 focus:bg-orange-100 focus:outline-hidden disabled:pointer-events-none disabled:opacity-50 dark:hover:bg-stone-100/5 dark:focus:bg-stone-100/5"
          >
            <span class="text-xs group-hover:hidden">•••</span>
            <svg
              class="hidden h-5 w-5 shrink-0 group-hover:block"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <>
                <path d="m6 17 5-5-5-5" />
                <path d="m13 17 5-5-5-5" />
              </>
            </svg>
            <span
              class="hs-tooltip-content hs-tooltip-shown:opacity-100 hs-tooltip-shown:visible invisible absolute z-10 inline-block rounded-sm bg-stone-900 px-2 py-1 text-xs font-medium text-stone-100 opacity-0 shadow-xs transition-opacity dark:bg-stone-700"
              role="tooltip"
            >
              {`Next ${totalPages - currentPage > 3 ? 3 : totalPages - currentPage} pages`}
            </span>
          </a>
        </div>
      )
    }

    {
      totalPages > 1 && (
        <a
          href={'/recipes?page=' + totalPages}
          class={`${baseStyle} ${currentPage === totalPages ? 'bg-orange-200 focus:bg-orange-200 dark:bg-stone-700 dark:text-stone-100 dark:focus:bg-gray-500' : 'hover:bg-orange-100 focus:bg-orange-100 dark:text-white dark:hover:bg-stone-100/5 dark:focus:bg-stone-100/5'}`}
          aria-current={currentPage === totalPages ? 'page' : undefined}
          aria-label={`Page ${totalPages}`}
        >
          {totalPages}
        </a>
      )
    }
  </div>
  {
    disableNext ? (
      <span class={disabledNavStyle} aria-disabled="true">
        <span class="hidden sm:inline-block">Next</span>
        <svg
          class="h-3.5 w-3.5 shrink-0"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m9 18 6-6-6-6" />
        </svg>
      </span>
    ) : (
      <a
        href={'/recipes?page=' + (currentPage + 1)}
        aria-label="Go to next page"
        class={navLinkStyle}
      >
        <span class="hidden sm:inline-block">Next</span>
        <svg
          class="h-3.5 w-3.5 shrink-0 transition ease-in-out group-hover:translate-x-1"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m9 18 6-6-6-6" />
        </svg>
      </a>
    )
  }
</nav>
