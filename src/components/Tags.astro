---
import { capitalize } from '../utils';
const { tags } = Astro.props;

interface Props {
  tags?: string[];
}
---

{
  tags?.map((tag: string) => (
    <a
      class="focus-visible:ring-secondary inline-flex items-center gap-x-1.5 rounded-lg bg-orange-400/30 px-3 py-1.5 text-xs font-medium text-orange-800 transition-colors duration-300 hover:bg-orange-500/30 focus:outline-hidden focus-visible:ring-1 focus-visible:outline-hidden xl:text-sm dark:bg-stone-700/60 dark:text-stone-300 dark:hover:bg-stone-600"
      data-astro-prefetch
      href={'/recipes/tag/' + tag}
    >
      {capitalize(tag)}
    </a>
  ))
}
