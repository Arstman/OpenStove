---
interface Props {
  title: string;
  description: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  title,
  description,
  primaryHref = '/recipes',
  primaryLabel = 'Browse recipes',
  secondaryHref,
  secondaryLabel,
} = Astro.props;
---

<div class="mx-auto flex max-w-lg flex-col items-center px-4 py-16 text-center">
  <h2
    class="text-dark text-xl font-bold text-balance sm:text-2xl dark:text-stone-100"
  >
    {title}
  </h2>
  <p class="mt-3 text-pretty text-stone-600 dark:text-stone-400">
    {description}
  </p>
  <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center">
    <a
      class="bg-secondary-accent text-on-brand hover:bg-secondary focus-visible:ring-secondary corner-squircle inline-flex items-center justify-center rounded-4xl px-6 py-3 font-medium transition duration-300 focus:outline-hidden focus-visible:ring-2"
      href={primaryHref}
      data-astro-prefetch
    >
      {primaryLabel}
    </a>
    {
      secondaryHref && secondaryLabel && (
        <a
          class="border-primary bg-primary text-on-brand corner-squircle dark:hover:text-primary inline-block rounded-4xl border-2 px-8 py-3 text-center text-sm font-medium outline-hidden transition duration-300 hover:-translate-y-1 hover:bg-transparent focus-visible:-translate-y-1 md:text-base"
          href={secondaryHref}
          data-astro-prefetch
        >
          {secondaryLabel}
        </a>
      )
    }
  </div>
</div>
