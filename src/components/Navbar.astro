          </a>
        </li>
        <li>
          <a
            href="/about"
            data-astro-prefetch
            class={currentPage.startsWith('about')
              ? 'block rounded-sm bg-primary-accent-dark px-3 py-2 text-dark transition-colors duration-300 focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-secondary md:bg-transparent md:p-0 md:text-secondary 2xl:text-lg dark:bg-stone-900 dark:text-primary-accent-dark md:dark:bg-transparent'
              : 'block rounded-sm px-3 py-2 text-dark transition-colors duration-300 hover:bg-orange-100 hover:text-primary-accent-dark focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-secondary md:p-0 md:hover:bg-transparent md:hover:text-secondary 2xl:text-lg dark:border-stone-700 dark:text-stone-100 dark:hover:bg-dark dark:hover:text-primary-accent-dark md:dark:hover:bg-transparent md:dark:hover:text-primary-accent-dark'}
