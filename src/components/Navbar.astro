          aria-controls="navbar-alignment"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <svg
            class="hs-collapse-open:hidden h-5 w-5"
            fill="none"
            id="open-menu-icon"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              class="text-dark fill-current dark:text-stone-100"
              d="M3 5H11"
