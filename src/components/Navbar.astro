          class="hs-dark-mode group focus-visible:ring-secondary hs-dark-mode-active:hidden corner-squircle inline-flex h-10 min-w-10 items-center justify-center rounded-4xl py-2 whitespace-nowrap transition-colors duration-300 hover:bg-orange-100 focus:outline-hidden focus-visible:ring-1 focus-visible:outline-hidden md:h-9 md:w-9 md:min-w-0 dark:hover:bg-stone-700"
