---
import { resolveRecipeImage } from '@/lib/recipeImage';

interface Props {
  image: string;
  imageAlt: string;
  class?: string;
  loading?: 'eager' | 'lazy';
  draggable?: boolean | 'true' | 'false';
  width?: number;
  height?: number;
  sizes?: string;
}

const {
  image,
  imageAlt,
  class: className = '',
  loading = 'lazy',
  draggable = 'false',
  width = 1200,
  height = 800,
  sizes = '(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 400px',
} = Astro.props;

const src = resolveRecipeImage(image);
---

<img
  class={`recipe-img ${className}`}
  src={src}
  alt={imageAlt || 'Recipe image'}
  width={width}
  height={height}
  sizes={sizes}
  loading={loading}
  decoding="async"
  draggable={draggable}
  data-fallback="/placeholder-recipe.png"
/>

<script>
  document
    .querySelectorAll<HTMLImageElement>('img.recipe-img[data-fallback]')
    .forEach(img => {
      img.addEventListener('error', () => {
        const fallback = img.dataset.fallback;
        if (fallback && img.src !== fallback) {
          img.src = fallback;
        }
      });
    });
</script>
