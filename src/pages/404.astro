---
export const prerender = true;
import MainLayout from '@layouts/MainLayout.astro';
---

<MainLayout title="404 – Page Not Found">
  <section class="grid h-svh place-content-center">
    <div class="mx-auto max-w-(--breakpoint-xl) px-4 py-8 lg:px-6 lg:py-16">
      <div class="mx-auto max-w-(--breakpoint-sm) text-center">
        <h1
          class="text-dark mb-4 text-7xl font-extrabold lg:text-9xl dark:text-stone-100"
        >
          404
        </h1>
        <p
          class="mb-4 text-3xl font-bold tracking-tight text-balance text-stone-700 md:text-4xl dark:text-stone-300"
        >
          Oh no, we've hit a snag!
        </p>
        <p class="mb-4 text-lg text-pretty text-stone-600 dark:text-stone-400">
          Sorry, we couldn't find the page you were looking for. Not to worry —
          a feast of possibilities awaits! Dive back into our Recipes page to
          find your next kitchen adventure.
        </p>
        <a
          class="bg-primary hover:shadow-primary inline-block rounded-xl px-8 py-3 text-center text-sm font-bold text-[#422006] outline-hidden transition duration-300 hover:-translate-y-1 hover:shadow-2xl focus-visible:-translate-y-1 md:text-base 2xl:text-lg"
          href="/recipes">Back to Recipes</a
        >
      </div>
    </div>
  </section>
</MainLayout>
