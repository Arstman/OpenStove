---
import MainLayout from '@layouts/MainLayout.astro';
import RecipeCard from '@components/RecipeCard.astro';
import EmptyState from '@components/EmptyState.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export const prerender = false;

let savedRecipes: CollectionEntry<'recipes'>[] = [];
const cookieObject = Astro.cookies.get('bookmarks');

const allRecipes: CollectionEntry<'recipes'>[] = await getCollection('recipes');

if (cookieObject) {
  try {
    const storedBookmarks = cookieObject.json() as unknown;
    if (Array.isArray(storedBookmarks)) {
      const ids = storedBookmarks.filter(
        (id): id is string => typeof id === 'string'
      );
      savedRecipes = allRecipes.filter(recipe => ids.includes(recipe.id));
    }
  } catch {
    savedRecipes = [];
  }
}
---

<MainLayout
  title="Saved Recipes | OpenStove"
  description="View your saved recipes on OpenStove. Access your bookmarked recipes anytime."
  canonicalUrl="/recipes/saved"
  robots="noindex, follow"
>
  <section class="min-h-screen">
    <div class="mt-10 py-6 sm:py-8 lg:py-12">
      <div
        class="corner-squircle from-brand-gold to-brand-warm rounded-[100px] bg-linear-to-r px-4 py-6 md:py-8 lg:py-12"
      >
        <h1
          class="text-dark mx-auto max-w-3xl text-center text-3xl font-bold text-balance sm:text-4xl md:text-5xl 2xl:max-w-4xl 2xl:text-6xl"
        >
          Saved Recipes
        </h1>
      </div>
    </div>

    <div id="recipeCards" class="mx-auto max-w-(--breakpoint-2xl)">
      {
        savedRecipes.length === 0 ? (
          <EmptyState
            title="No saved recipes yet"
            description="Tap the bookmark icon on any recipe to save it here. Bookmarks are stored in a cookie in this browser."
            primaryHref="/recipes"
            primaryLabel="Browse recipes"
          />
        ) : (
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {savedRecipes.map(recipe => (
              <RecipeCard recipe={recipe} />
            ))}
          </div>
        )
      }
    </div>
  </section>
</MainLayout>
