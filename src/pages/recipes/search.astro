---
import MainLayout from '@layouts/MainLayout.astro';
import RecipeCard from '@components/RecipeCard.astro';
import EmptyState from '@components/EmptyState.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export const prerender = false;

const rawQuery = Astro.url.searchParams.get('query');
const query = rawQuery?.trim() ?? '';

const allRecipes: CollectionEntry<'recipes'>[] = await getCollection('recipes');

const searchResults =
  query.length > 0
    ? allRecipes.filter(recipe => {
        const q = query.toLowerCase();

        const titleMatch = recipe.data.title.toLowerCase().includes(q);
        const descriptionMatch = recipe.data.description
          .toLowerCase()
          .includes(q);
        const authorMatch = recipe.data.author.toLowerCase().includes(q);
        const idMatch = recipe.id.toLowerCase().includes(q);
        const notesMatch = recipe.data.recipeNotes
          ? recipe.data.recipeNotes.some(note => note.toLowerCase().includes(q))
          : false;
        const instructionsMatch = recipe.data.steps.some(step =>
          step.actions.some(action => action.toLowerCase().includes(q))
        );

        return (
          titleMatch ||
          descriptionMatch ||
          authorMatch ||
          idMatch ||
          notesMatch ||
          instructionsMatch
        );
      })
    : [];

const canonicalUrl = '/recipes/search';
const pageDescription = query
  ? `Search results for "${query}" on OpenStove. Found ${searchResults.length} recipes.`
  : 'Search recipes on OpenStove. Find your favorite dishes from our community-crafted collection.';

const heading = query ? `Results for “${query}”` : 'Search recipes';
---

<MainLayout
  title={query
    ? `Search Results for "${query}" | OpenStove`
    : 'Search | OpenStove'}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  robots="noindex, follow"
>
  <section class="min-h-screen">
    <div class="mt-10 py-6 sm:py-8 lg:py-12">
      <div
        class="corner-squircle from-brand-gradient-a to-brand-gradient-b rounded-[100px] bg-linear-to-r px-4 py-6 md:py-8 lg:py-12"
      >
        <h1
          class="mx-auto max-w-3xl text-center text-3xl font-bold text-balance text-stone-800 sm:text-4xl md:text-5xl 2xl:max-w-4xl 2xl:text-6xl"
        >
          {heading}
        </h1>
      </div>
    </div>

    <div id="recipeCards" class="mx-auto max-w-(--breakpoint-2xl)">
      {
        !query ? (
          <EmptyState
            title="Search the recipe library"
            description="Type at least two characters in the search bar above to find recipes by title, ingredients, or instructions."
            primaryHref="/recipes"
            primaryLabel="Browse all recipes"
          />
        ) : searchResults.length === 0 ? (
          <EmptyState
            title={`No recipes match “${query}”`}
            description="Try a shorter phrase, a different dish name, or browse the full collection."
            primaryHref="/recipes"
            primaryLabel="Browse recipes"
            secondaryHref="/"
            secondaryLabel="Back to home"
          />
        ) : (
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {searchResults.map(recipe => (
              <RecipeCard recipe={recipe} />
            ))}
          </div>
        )
      }
    </div>
  </section>
</MainLayout>
