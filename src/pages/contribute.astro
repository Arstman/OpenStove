---
import MainLayout from '@layouts/MainLayout.astro';

export const prerender = false;

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
const formConfigured = Boolean(
  import.meta.env.GITHUB_TOKEN && import.meta.env.GITHUB_REPO
);
---

<MainLayout
  title="Contribute a Recipe | OpenStove"
  description="Share your recipe with the OpenStove community via an easy online form."
  type="website"
>
  <section class="mx-auto max-w-2xl px-4 py-16 sm:px-6 lg:py-20">
    <h1
      class="text-dark text-3xl font-bold text-balance sm:text-4xl dark:text-stone-100"
    >
      Contribute a Recipe
    </h1>
    <p class="mt-4 text-stone-600 2xl:text-lg dark:text-stone-400">
      Submit a recipe for review. We'll turn it into Markdown, add a licensed
      photo when needed, and publish it on OpenStove. Prefer Git?{' '}
      <a
        class="text-dark dark:hover:text-primary underline decoration-2 underline-offset-2 hover:text-orange-600 dark:text-stone-200"
        href="https://github.com/mearashadowfax/OpenStove/blob/main/CONTRIBUTING.md"
        target="_blank"
        rel="noopener noreferrer">Open a pull request</a
      >{' '}instead.
    </p>

    {
      !formConfigured && (
        <p
          class="mt-6 rounded-lg border border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-900 dark:border-amber-700/50 dark:bg-amber-950/40 dark:text-amber-100"
          role="status"
        >
          Form submission is not configured on this environment yet
          (GITHUB_TOKEN / GITHUB_REPO). You can still use the GitHub PR flow.
        </p>
      )
    }

    <form
      id="contribute-form"
      class="mt-10 space-y-6"
      method="POST"
      action="/api/contribute"
    >
      <div>
        <label
          for="title"
          class="text-dark mb-1.5 block text-sm font-medium dark:text-stone-200"
          >Dish title *</label
        >
        <input
          id="title"
          name="title"
          type="text"
          required
          maxlength="120"
          class="text-dark focus:border-secondary focus:ring-secondary w-full rounded-lg border border-orange-200 bg-white px-3 py-2.5 dark:border-stone-600 dark:bg-stone-900 dark:text-stone-100"
        />
      </div>

      <div>
        <label
          for="description"
          class="text-dark mb-1.5 block text-sm font-medium dark:text-stone-200"
          >Short description *</label
        >
        <textarea
          id="description"
          name="description"
          required
          rows="3"
          maxlength="500"
          class="text-dark focus:border-secondary focus:ring-secondary w-full rounded-lg border border-orange-200 bg-white px-3 py-2.5 dark:border-stone-600 dark:bg-stone-900 dark:text-stone-100"
        ></textarea>
      </div>

      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <label
            for="author"
            class="text-dark mb-1.5 block text-sm font-medium dark:text-stone-200"
            >Your name or alias</label
          >
          <input
            id="author"
            name="author"
            type="text"
            maxlength="80"
            placeholder="anonymous"
            class="text-dark focus:border-secondary focus:ring-secondary w-full rounded-lg border border-orange-200 bg-white px-3 py-2.5 dark:border-stone-600 dark:bg-stone-900 dark:text-stone-100"
          />
        </div>
        <div>
          <label
            for="cookingTime"
            class="text-dark mb-1.5 block text-sm font-medium dark:text-stone-200"
            >Cooking time (minutes) *</label
          >
          <input
            id="cookingTime"
            name="cookingTime"
            type="number"
            required
            min="1"
            max="999"
            class="text-dark focus:border-secondary focus:ring-secondary w-full rounded-lg border border-orange-200 bg-white px-3 py-2.5 dark:border-stone-600 dark:bg-stone-900 dark:text-stone-100"
          />
        </div>
      </div>

      <div>
        <label
          for="ingredients"
          class="text-dark mb-1.5 block text-sm font-medium dark:text-stone-200"
          >Ingredients *</label
        >
        <p class="mb-1.5 text-xs text-stone-500 dark:text-stone-400">
          One ingredient per line. Optional format: quantity | unit | name
        </p>
        <textarea
          id="ingredients"
          name="ingredients"
          required
          rows="8"
          placeholder={'1/2 | cup | flour\nSalt and pepper to taste'}
          class="text-dark focus:border-secondary focus:ring-secondary w-full rounded-lg border border-orange-200 bg-white px-3 py-2.5 font-mono text-sm dark:border-stone-600 dark:bg-stone-900 dark:text-stone-100"
        ></textarea>
      </div>

      <div>
        <label
          for="steps"
          class="text-dark mb-1.5 block text-sm font-medium dark:text-stone-200"
          >Steps *</label
        >
        <p class="mb-1.5 text-xs text-stone-500 dark:text-stone-400">
          One action per line. Start a new section with ## Section title
        </p>
        <textarea
          id="steps"
          name="steps"
          required
          rows="10"
          placeholder={'## Prep\nChop the onions.\n## Cook\nSauté until soft.'}
          class="text-dark focus:border-secondary focus:ring-secondary w-full rounded-lg border border-orange-200 bg-white px-3 py-2.5 font-mono text-sm dark:border-stone-600 dark:bg-stone-900 dark:text-stone-100"
        ></textarea>
      </div>

      <div>
        <label
          for="notes"
          class="text-dark mb-1.5 block text-sm font-medium dark:text-stone-200"
          >Recipe notes</label
        >
        <textarea
          id="notes"
          name="notes"
          rows="3"
          maxlength="1000"
          placeholder="Tips, substitutions, warnings…"
          class="text-dark focus:border-secondary focus:ring-secondary w-full rounded-lg border border-orange-200 bg-white px-3 py-2.5 dark:border-stone-600 dark:bg-stone-900 dark:text-stone-100"
        ></textarea>
      </div>

      <div>
        <label
          for="tags"
          class="text-dark mb-1.5 block text-sm font-medium dark:text-stone-200"
          >Tags</label
        >
        <input
          id="tags"
          name="tags"
          type="text"
          maxlength="120"
          placeholder="soup, vegetarian, quick (max 3)"
          class="text-dark focus:border-secondary focus:ring-secondary w-full rounded-lg border border-orange-200 bg-white px-3 py-2.5 dark:border-stone-600 dark:bg-stone-900 dark:text-stone-100"
        />
      </div>

      <div>
        <label
          for="imageUrl"
          class="text-dark mb-1.5 block text-sm font-medium dark:text-stone-200"
          >Image URL (optional)</label
        >
        <p class="mb-1.5 text-xs text-stone-500 dark:text-stone-400">
          Link to a photo you own or have rights to use. Do not upload binaries
          via PR – maintainers host licensed photos separately.
        </p>
        <input
          id="imageUrl"
          name="imageUrl"
          type="url"
          maxlength="500"
          placeholder="https://"
          class="text-dark focus:border-secondary focus:ring-secondary w-full rounded-lg border border-orange-200 bg-white px-3 py-2.5 dark:border-stone-600 dark:bg-stone-900 dark:text-stone-100"
        />
      </div>

      {/* Honeypot */}
      <div class="hidden" aria-hidden="true">
        <label for="website">Website</label>
        <input
          id="website"
          name="website"
          type="text"
          tabindex="-1"
          autocomplete="off"
        />
      </div>

      {
        turnstileSiteKey && (
          <div
            class="cf-turnstile"
            data-sitekey={turnstileSiteKey}
            data-theme="auto"
          />
        )
      }

      <p
        id="form-status"
        class="hidden text-sm"
        role="status"
        aria-live="polite"
      >
      </p>

      <div class="flex flex-wrap items-center gap-3">
        <a
          id="form-result-link"
          class="bg-primary text-dark hover:bg-primary-accent-light focus-visible:ring-primary hidden w-fit items-center justify-center rounded-lg px-5 py-2.5 font-medium transition-colors focus-visible:ring-2 focus-visible:outline-hidden"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
        >
          View submission on GitHub
        </a>

        <button
          type="submit"
          id="contribute-submit"
          disabled={!formConfigured}
          class="bg-secondary text-dark hover:bg-secondary-accent focus-visible:ring-secondary inline-flex items-center justify-center rounded-lg px-5 py-2.5 font-medium transition-colors focus-visible:ring-2 focus-visible:outline-hidden disabled:cursor-not-allowed disabled:opacity-50"
        >
          Submit for review
        </button>
      </div>
    </form>
  </section>
</MainLayout>

{
  turnstileSiteKey && (
    <script
      is:inline
      src="https://challenges.cloudflare.com/turnstile/v0/api.js"
      async
      defer
    />
  )
}

<script>
  const form = document.getElementById(
    'contribute-form'
  ) as HTMLFormElement | null;
  const statusEl = document.getElementById('form-status');
  const submitBtn = document.getElementById(
    'contribute-submit'
  ) as HTMLButtonElement | null;
  const resultLink = document.getElementById(
    'form-result-link'
  ) as HTMLAnchorElement | null;

  form?.addEventListener('submit', async event => {
    event.preventDefault();
    if (!form || !statusEl || !submitBtn) return;

    statusEl.classList.add('hidden');
    resultLink?.classList.add('hidden');
    resultLink?.classList.remove('inline-flex');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting…';

    try {
      const response = await fetch('/api/contribute', {
        method: 'POST',
        body: new FormData(form),
      });
      const data = (await response.json()) as {
        ok?: boolean;
        error?: string;
        url?: string;
      };

      if (!response.ok || !data.ok) {
        throw new Error(data.error || 'Submission failed. Please try again.');
      }

      statusEl.textContent = 'Thanks! Your recipe was submitted for review.';
      statusEl.className = 'text-sm text-green-700 dark:text-green-400';
      if (data.url && resultLink) {
        resultLink.href = data.url;
        resultLink.classList.remove('hidden');
        resultLink.classList.add('inline-flex');
      }
      form.reset();
    } catch (error) {
      resultLink?.classList.add('hidden');
      resultLink?.classList.remove('inline-flex');
      statusEl.textContent =
        error instanceof Error ? error.message : 'Something went wrong.';
      statusEl.className = 'text-sm text-red-700 dark:text-red-400';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit for review';
    }
  });
</script>
