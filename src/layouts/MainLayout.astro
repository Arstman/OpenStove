---
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import Meta from '@components/Meta.astro';
import '@styles/global.css';

const {
  title = 'OpenStove',
  description,
  image,
  type,
  url,
  canonicalUrl,
  recipeData,
} = Astro.props;

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  url?: string;
  canonicalUrl?: string;
  recipeData?: {
    author?: string;
    pubDate?: Date;
    cookingTime?: number;
    servings?: number;
    ingredients?: Array<{
      title?: string;
      items: Array<{
        quantity?: string;
        name: string;
      }>;
    }>;
    steps?: Array<{
      title?: string;
      actions: string[];
    }>;
  };
}

const currentUrl = url ?? canonicalUrl ?? Astro.url.href;
---

<html class="scroll-pt-16 scroll-smooth" lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <Meta
      url={currentUrl}
      title={title}
      description={description}
      image={image}
      type={type}
      recipeData={recipeData}
    />
    <script is:inline>
      'dark' === localStorage.getItem('hs_theme') ||
      (!('hs_theme' in localStorage) &&
        window.matchMedia('(prefers-color-scheme: dark)').matches)
        ? document.documentElement.classList.add('dark')
        : document.documentElement.classList.remove('dark');
    </script>
    <style>
      body {
        overflow-y: scroll;
      }
      body::-webkit-scrollbar {
        width: 0.5rem;
      }
      @media (min-width: 1536px) {
        body::-webkit-scrollbar {
          width: 0.75rem;
        }
      }
      body::-webkit-scrollbar-track {
        background: #f5f5f4;
        border-radius: 9999px;
      }
      body::-webkit-scrollbar-thumb {
        background: #ff9a6c;
        border-radius: 9999px;
      }
      .dark body::-webkit-scrollbar-track {
        background: #44403c;
      }
      .dark body::-webkit-scrollbar-thumb {
        background: #ffc53d;
      }
    </style>
  </head>
  <body
    class="text-dark selection:bg-secondary dark:bg-dark dark:selection:bg-primary bg-orange-50 selection:text-stone-700 dark:text-stone-100 dark:selection:text-stone-700"
  >
    <div class="mx-auto max-w-(--breakpoint-2xl) px-4 md:px-8">
      <Navbar />
      <slot />
    </div>
    <Footer />
    <script>
      import { HSStaticMethods } from 'preline';
      function initPreline() {
        HSStaticMethods.autoInit();
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initPreline);
      } else {
        initPreline();
      }
    </script>
  </body>
</html>
