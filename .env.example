# Public site URL used by Astro (optional locally)
# PUBLIC_SITE_URL=http://localhost:4321

# CDN base for recipe photos (no trailing slash). Filenames in frontmatter are appended.
# Example after running scripts/upload-recipe-images.mjs:
# PUBLIC_IMAGE_BASE_URL=https://xxxxx.public.blob.vercel-storage.com/recipes

# Vercel Blob token (upload script only – do not expose to the client)
# BLOB_READ_WRITE_TOKEN=

# GitHub – contribute form creates Issues on this repo
# GITHUB_TOKEN=ghp_... or fine-scoped PAT with issues:write
# GITHUB_REPO=mearashadowfax/OpenStove

# Cloudflare Turnstile (spam protection on /contribute)
# PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Keystatic GitHub mode (production admin at /keystatic)
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_SECRET=
# PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
